{
  "name": "@vicsee/mcp-server",
  "version": "0.3.1",
  "description": "MCP server for VicSee — generate, edit, and upscale AI video & images from any agent (Hermes, Claude, Cursor, OpenClaw).",
  "mcpName": "io.github.vicseeai/vicsee-mcp-server",
  "type": "module",
  "bin": {
    "vicsee-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "deploy": "wrangler deploy",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "vicsee",
    "ai-image",
    "ai-video",
    "image-generation",
    "video-generation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/vicseeai/vicsee-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vicseeai/vicsee-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/vicseeai/vicsee-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@types/node": "^22.10.0",
    "agents": "^0.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.100.0"
  }
}
